<?php

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Entity\EntityInterface;
use Drupal\node\NodeInterface;
use Drupal\muteti_seb\Service\UserDepartment;
use Drupal\muteti_seb\Service\DepartmentMode;

/**
 * Implements hook_preprocess_menu().
 */
function muteti_seb_preprocess_menu(array &$variables): void {
  if (DepartmentMode::get(UserDepartment::get(\Drupal::currentUser())) !== 'onko') {
    return;
  }

  $variables['#cache']['contexts'][] = 'user.roles';
  muteti_seb_remove_oncology_surgery_links($variables['items']);
}

/**
 * Removes surgery-allocation links from a rendered menu tree.
 */
function muteti_seb_remove_oncology_surgery_links(array &$items): void {
  foreach ($items as $key => &$item) {
    $title = trim((string) ($item['title'] ?? ''));
    $route = isset($item['url']) && $item['url']->isRouted()
      ? $item['url']->getRouteName()
      : '';
    if ($title === 'Műtéti beosztás' || $title === 'Műtők beosztása' || $route === 'muteti_seb.surgery') {
      unset($items[$key]);
      continue;
    }
    if (!empty($item['below'])) {
      muteti_seb_remove_oncology_surgery_links($item['below']);
    }
  }
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function muteti_seb_form_user_login_form_alter(array &$form, FormStateInterface $form_state): void {
  $form['#submit'][] = 'muteti_seb_login_redirect_submit';
}

/**
 * Sends application users to their department-aware booking page after login.
 */
function muteti_seb_login_redirect_submit(array &$form, FormStateInterface $form_state): void {
  if (!\Drupal::request()->query->has('destination')) {
    $form_state->setRedirect('muteti_seb.home');
  }
}

/**
 * Implements hook_entity_presave().
 *
 * Keeps the application registry compatible while Orvos nodes become the
 * Drupal administration source of truth.
 */
function muteti_seb_entity_presave(EntityInterface $entity): void {
  if (!$entity instanceof NodeInterface) {
    return;
  }
  if ($entity->bundle() === 'muteti_day_type_definition') {
    $department = trim((string) $entity->get('field_muteti_daytype_department')->value);
    $code = trim((string) $entity->get('field_muteti_daytype_code')->value);
    $from = trim((string) $entity->get('field_muteti_daytype_from')->value);
    $until = trim((string) $entity->get('field_muteti_daytype_until')->value);
    $title = $department . ' – ' . $code;
    if ($from !== '' || $until !== '') {
      $title .= ' (' . ($from ?: 'kezdet') . ' – ' . ($until ?: 'folyamatos') . ')';
    }
    $entity->setTitle($title);
    return;
  }
  if ($entity->bundle() !== 'muteti_doctor') {
    return;
  }
  $database = \Drupal::database();
  $registry_id = (int) ($entity->get('field_muteti_registry_id')->value ?? 0);
  $fields = [
    'legacy_nid' => $entity->get('field_muteti_legacy_nid')->value ?: NULL,
    'user_id' => $entity->get('field_muteti_user')->target_id ?: NULL,
    'name' => trim((string) $entity->label()),
    'background_color' => $entity->get('field_muteti_background')->value ?: '#eef2f6',
    'text_color' => $entity->get('field_muteti_text_color')->value ?: '#111111',
    'department' => $entity->get('field_muteti_department')->value ?: 'Sebészet',
    'active' => (int) (bool) $entity->get('field_muteti_active')->value,
  ];
  if ($database->schema()->fieldExists('muteti_doctor', 'background_gif')) {
    $gif = $entity->hasField('field_muteti_background_gif')
      ? $entity->get('field_muteti_background_gif')->entity
      : NULL;
    $fields['background_gif'] = $gif ? $gif->getFileUri() : NULL;
  }
  if ($registry_id && $database->select('muteti_doctor', 'd')->condition('id', $registry_id)->countQuery()->execute()->fetchField()) {
    $database->update('muteti_doctor')->fields($fields)->condition('id', $registry_id)->execute();
  }
  else {
    $registry_id = (int) $database->insert('muteti_doctor')->fields($fields)->execute();
    $entity->set('field_muteti_registry_id', $registry_id);
  }
}

/**
 * Implements hook_entity_delete().
 */
function muteti_seb_entity_delete(EntityInterface $entity): void {
  if ($entity instanceof NodeInterface && $entity->bundle() === 'muteti_doctor') {
    $registry_id = (int) ($entity->get('field_muteti_registry_id')->value ?? 0);
    if ($registry_id) {
      // Keep historical appointment references valid.
      \Drupal::database()->update('muteti_doctor')->fields(['active' => 0])->condition('id', $registry_id)->execute();
    }
  }
}

/**
 * Implements hook_form_alter().
 */
function muteti_seb_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $form_object = $form_state->getFormObject();
  if (!method_exists($form_object, 'getEntity')) {
    return;
  }
  $entity = $form_object->getEntity();
  if ($entity instanceof NodeInterface && $entity->bundle() === 'muteti_article') {
    if (isset($form['field_muteti_article_department']['widget'][0]['value'])) {
      $names = \Drupal::database()->select('muteti_department_config', 'd')->fields('d', ['name'])->orderBy('name')->execute()->fetchCol();
      $form['field_muteti_article_department']['widget'][0]['value']['#type'] = 'select';
      $form['field_muteti_article_department']['widget'][0]['value']['#options'] = ['all' => 'Minden osztály'] + array_combine($names, $names);
    }
    return;
  }
  if ($entity instanceof NodeInterface && $entity->bundle() === 'muteti_day_type_definition') {
    if (isset($form['field_muteti_daytype_department']['widget'][0]['value'])) {
      $names = \Drupal::database()->select('muteti_department_config', 'd')->fields('d', ['name'])->orderBy('name')->execute()->fetchCol();
      $form['field_muteti_daytype_department']['widget'][0]['value']['#type'] = 'select';
      $form['field_muteti_daytype_department']['widget'][0]['value']['#options'] = array_combine($names, $names);
    }
    foreach (['field_muteti_daytype_from', 'field_muteti_daytype_until'] as $field_name) {
      if (isset($form[$field_name]['widget'][0]['value'])) {
        $form[$field_name]['widget'][0]['value']['#type'] = 'date';
      }
    }
    if (isset($form['field_muteti_daytype_slots']['widget'][0]['value'])) {
      $form['field_muteti_daytype_slots']['widget'][0]['value']['#description'] =
        'A cellatípusokat % jellel válassza el. Üres helyet két egymást követő % jellel lehet megadni.';
      $form['field_muteti_daytype_slots']['widget'][0]['value']['#rows'] = 5;
    }
    if (isset($form['title']['widget'][0]['value'])) {
      $form['title']['widget'][0]['value']['#default_value'] = $entity->label() ?: 'Automatikus napfajtanév';
      $form['title']['widget'][0]['value']['#description'] = 'Mentéskor automatikusan az osztály és a napfajta jele alapján készül el.';
    }
    return;
  }
  if (!$entity instanceof NodeInterface || $entity->bundle() !== 'muteti_doctor') {
    return;
  }

  foreach (['field_muteti_background' => '#eef2f6', 'field_muteti_text_color' => '#111111'] as $field => $fallback) {
    if (isset($form[$field]['widget'][0]['value'])) {
      $form[$field]['widget'][0]['value']['#type'] = 'color';
      $form[$field]['widget'][0]['value']['#default_value'] = $entity->get($field)->value ?: $fallback;
    }
  }
  if (isset($form['field_muteti_department']['widget'][0]['value'])) {
    $names = \Drupal::database()->select('muteti_department_config', 'd')->fields('d', ['name'])->orderBy('name')->execute()->fetchCol();
    $form['field_muteti_department']['widget'][0]['value']['#type'] = 'select';
    $form['field_muteti_department']['widget'][0]['value']['#options'] = array_combine($names, $names);
  }
  $form['field_muteti_registry_id']['#access'] = FALSE;
  $form['field_muteti_legacy_nid']['#access'] = FALSE;
}
