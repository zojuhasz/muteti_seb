      'acute_1' => ['type' => 'varchar', 'length' => 255, 'not null' => TRUE, 'default' => ''],
      'acute_2' => ['type' => 'varchar', 'length' => 255, 'not null' => TRUE, 'default' => ''],
      'ambulance' => ['type' => 'varchar', 'length' => 255, 'not null' => TRUE, 'default' => ''],
      'other_absent' => ['type' => 'text', 'not null' => FALSE],
