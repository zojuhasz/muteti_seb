    ],
    'primary key' => ['id'],
    'indexes' => ['created' => ['created'], 'user_id' => ['user_id']],
  ];
  $schema['muteti_on_call'] = [
    'description' => 'Működési módonként és naponként az első ügyeletes orvos.',
