/**
 * Makes the basic Orvos role strictly read-only.
 */
function muteti_seb_update_11023(): void {
  $role = Role::load('muteti_orvos3');
  if (!$role) {
    return;
  }
  foreach ([
    'create surgery appointment',
    'edit surgery appointment',
    'assign operating room',
    'administer surgery system',
    'manage own doctor availability',
    'view doctor availability',
  ] as $permission) {
    $role->revokePermission($permission);
  }
  $role->grantPermission('view surgery schedule');
  $role->save();
}

/**
 * Allows Orvos1 and higher roles to move and duplicate appointments.
 */
function muteti_seb_update_11024(): void {
  foreach (['muteti_orvos1', 'muteti_orvos2', 'muteti_boss'] as $role_id) {
    if ($role = Role::load($role_id)) {
      $role->grantPermission('move surgery appointment');
      $role->save();
    }
  }
}

