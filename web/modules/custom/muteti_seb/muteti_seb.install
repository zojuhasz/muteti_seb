}

/**
 * Implements hook_install().
 */
function muteti_seb_install(): void {
  $roles = [
    'muteti_view' => ['Betekintő', ['view surgery schedule']],
    'muteti_orvos1' => ['Orvos1', ['view surgery schedule', 'create surgery appointment', 'edit surgery appointment', 'move surgery appointment', 'manage own doctor availability', 'view doctor availability']],
    'muteti_orvos2' => ['Orvos2', ['view surgery schedule', 'create surgery appointment', 'edit surgery appointment', 'move surgery appointment', 'assign operating room', 'manage own doctor availability', 'view doctor availability']],
    'muteti_orvos3' => ['Orvos', ['view surgery schedule']],
    'muteti_boss' => ['Boss', ['view surgery schedule', 'create surgery appointment', 'edit surgery appointment', 'move surgery appointment', 'assign operating room', 'administer surgery system', 'manage own doctor availability', 'view doctor availability']],
    'muteti_department_seb' => ['Osztály: Sebészet', []],
    'muteti_department_urol' => ['Osztály: Urológia', []],
    'muteti_department_onkorad' => ['Osztály: Onkoradiológia', []],
  ];
  foreach ($roles as $id => [$label, $permissions]) {
    $role = Role::load($id) ?? Role::create(['id' => $id, 'label' => $label]);
    foreach ($permissions as $permission) {
      $role->grantPermission($permission);
    }
    $role->save();
  }
  $departments = [
    ['Sebészet', 'sebeszet', 'seb', 'muteti_department_seb'],
    ['Urológia', 'urologia', 'urol', 'muteti_department_urol'],
    ['Onkoradiológia', 'onkoradiologia', 'onko', 'muteti_department_onkorad'],
  ];
  foreach ($departments as [$name, $machine_name, $mode, $role_id]) {
    \Drupal::database()->insert('muteti_department_config')->fields(compact('name', 'machine_name', 'mode', 'role_id'))->execute();
  }
  muteti_seb_ensure_doctor_content_type();
  muteti_seb_ensure_article_content_type();
  muteti_seb_ensure_day_type_content_type();
  muteti_seb_seed_day_type_nodes();
  \Drupal::configFactory()->getEditable('system.site')->set('page.front', '/muteti/nyito')->save();
}

/**
 * Adds the department field to the doctor registry.
 */
function muteti_seb_update_11001(): void {
  $schema = \Drupal::database()->schema();
  if (!$schema->fieldExists('muteti_doctor', 'department')) {
    $schema->addField('muteti_doctor', 'department', [
      'type' => 'varchar',
      'length' => 50,
      'not null' => TRUE,
      'default' => 'Sebészet',
      'description' => 'Az orvos osztálya.',
    ]);
  }
}

/**
 * Stores the department on appointments so all D7 departments can coexist.
 */
function muteti_seb_update_11002(): void {
  $schema = \Drupal::database()->schema();
  if (!$schema->fieldExists('muteti_appointment', 'department')) {
    $schema->addField('muteti_appointment', 'department', [
      'type' => 'varchar',
      'length' => 50,
      'not null' => TRUE,
      'default' => 'Sebészet',
      'description' => 'Az előjegyzés osztálya.',
    ]);
  }
  if ($schema->indexExists('muteti_appointment', 'date_slot')) {
    $schema->dropUniqueKey('muteti_appointment', 'date_slot');
  }
  if (!$schema->indexExists('muteti_appointment', 'department_date_slot')) {
    $schema->addUniqueKey('muteti_appointment', 'department_date_slot', ['department', 'admission_date', 'slot_type']);
  }
}

/**
 * Adds department roles used to select the application after login.
 */
function muteti_seb_update_11003(): void {
  $roles = [
    'muteti_department_seb' => 'Osztály: Sebészet',
    'muteti_department_urol' => 'Osztály: Urológia',
    'muteti_department_onkorad' => 'Osztály: Onkoradiológia',
  ];
  foreach ($roles as $id => $label) {
    $role = Role::load($id) ?? Role::create(['id' => $id, 'label' => $label]);
    $role->save();
  }
}

/**
 * Adds the D7-to-D11 user mapping used for authoritative password sync.
 */
function muteti_seb_update_11004(): void {
  $schema = \Drupal::database()->schema();
  if (!$schema->tableExists('muteti_legacy_user')) {
    $definition = muteti_seb_schema()['muteti_legacy_user'];
    $schema->createTable('muteti_legacy_user', $definition);
  }
}

/**
 * Makes stored surgery day types department-specific.
 */
function muteti_seb_update_11005(): void {
  $schema = \Drupal::database()->schema();
  if (!$schema->fieldExists('muteti_day_type', 'department')) {
    $schema->addField('muteti_day_type', 'department', [
      'type' => 'varchar',
      'length' => 50,
      'not null' => TRUE,
      'default' => 'Sebészet',
      'description' => 'A napfajta osztálya.',
    ]);
  }
  $schema->dropPrimaryKey('muteti_day_type');
  $schema->addPrimaryKey('muteti_day_type', ['department', 'date']);
}

/**
 * Renames the highest doctor role from Orvos3 to Orvos.
 */
function muteti_seb_update_11006(): void {
  $role = Role::load('muteti_orvos3');
  if ($role) {
    $role->set('label', 'Orvos');
    $role->save();
  }
}

/**
 * Adds the Boss role imported from Drupal 7.
 */
function muteti_seb_update_11007(): void {
  $role = Role::load('muteti_boss') ?? Role::create([
    'id' => 'muteti_boss',
    'label' => 'Boss',
  ]);
  foreach ([
    'view surgery schedule',
    'create surgery appointment',
    'edit surgery appointment',
    'assign operating room',
    'administer surgery system',
  ] as $permission) {
    $role->grantPermission($permission);
  }
  $role->save();
}

/**
 * Adds the configurable department-to-operating-mode registry.
 */
function muteti_seb_update_11008(): void {
  $schema = \Drupal::database()->schema();
  if (!$schema->tableExists('muteti_department_config')) {
    $schema->createTable('muteti_department_config', muteti_seb_schema()['muteti_department_config']);
  }
  $departments = [
    ['Sebészet', 'sebeszet', 'seb', 'muteti_department_seb'],
    ['Urológia', 'urologia', 'urol', 'muteti_department_urol'],
    ['Onkoradiológia', 'onkoradiologia', 'onko', 'muteti_department_onkorad'],
  ];
  foreach ($departments as [$name, $machine_name, $mode, $role_id]) {
    \Drupal::database()->merge('muteti_department_config')
      ->key('machine_name', $machine_name)
      ->fields(compact('name', 'mode', 'role_id'))
      ->execute();
  }
}

/**
 * Adds the printable appointment audit log.
 */
function muteti_seb_update_11009(): void {
  $schema = \Drupal::database()->schema();
  if (!$schema->tableExists('muteti_audit_log')) {
    $schema->createTable('muteti_audit_log', muteti_seb_schema()['muteti_audit_log']);
  }
}

/**
 * Adds the imported daily on-call doctor registry.
 */
function muteti_seb_update_11010(): void {
  $schema = \Drupal::database()->schema();
  if (!$schema->tableExists('muteti_on_call')) {
    $schema->createTable('muteti_on_call', muteti_seb_schema()['muteti_on_call']);
  }
}

/**
 * Adds the second surgical on-call doctor imported from U2.
 */
function muteti_seb_update_11011(): void {
  $schema = \Drupal::database()->schema();
  if (!$schema->fieldExists('muteti_on_call', 'doctor_name_2')) {
    $schema->addField('muteti_on_call', 'doctor_name_2', [
      'type' => 'varchar',
      'length' => 100,
      'not null' => TRUE,
      'default' => '',
    ]);
  }
}

/**
 * Registers the existing doctor registry as a Drupal content entity.
 *
 * The entity deliberately keeps the existing muteti_doctor base table and
 * numeric IDs, so every appointment and assistant reference remains valid.
 */
function muteti_seb_update_11012(): void {
  $entity_type_manager = \Drupal::entityTypeManager();
  $entity_type_manager->clearCachedDefinitions();
  $entity_type = $entity_type_manager->getDefinition('muteti_doctor');
  $field_definitions = \Drupal::service('entity_field.manager')->getFieldStorageDefinitions('muteti_doctor');
  $repository = \Drupal::service('entity.last_installed_schema.repository');

  // The physical table already exists from earlier module versions. Record
  // its entity schema metadata without trying to create the table again.
  $repository->setLastInstalledDefinition($entity_type);
  foreach ($field_definitions as $field_definition) {
    $repository->setLastInstalledFieldStorageDefinition($field_definition);
  }
}

/**
 * Creates the real Drupal Orvos content type and migrates the registry.
 */
function muteti_seb_update_11013(): void {
  muteti_seb_ensure_doctor_content_type();

  $database = \Drupal::database();
  $doctors = $database->select('muteti_doctor', 'd')->fields('d')->execute();
  $node_storage = \Drupal::entityTypeManager()->getStorage('node');
  foreach ($doctors as $doctor) {
    $existing = $node_storage->getQuery()
      ->accessCheck(FALSE)
      ->condition('type', 'muteti_doctor')
      ->condition('field_muteti_registry_id', (int) $doctor->id)
      ->range(0, 1)
      ->execute();
    if ($existing) {
      continue;
    }
    $node = $node_storage->create([
      'type' => 'muteti_doctor',
      'title' => $doctor->name,
      'status' => 1,
      'uid' => 1,
      'field_muteti_registry_id' => (int) $doctor->id,
      'field_muteti_legacy_nid' => $doctor->legacy_nid ?: NULL,
      'field_muteti_user' => $doctor->user_id ?: NULL,
      'field_muteti_department' => $doctor->department,
      'field_muteti_background' => $doctor->background_color ?: '#eef2f6',
      'field_muteti_background_gif' => [],
      'field_muteti_text_color' => $doctor->text_color ?: '#111111',
      'field_muteti_active' => (bool) $doctor->active,
    ]);
    $node->save();
  }
}

/**
 * Ensures the Drupal node type and its base application fields exist.
 */
function muteti_seb_ensure_doctor_content_type(): void {
  $type = \Drupal\node\Entity\NodeType::load('muteti_doctor');
  if (!$type) {
    $type = \Drupal\node\Entity\NodeType::create([
      'type' => 'muteti_doctor',
      'name' => 'Orvos',
      'description' => 'Orvosok, felhasználói kapcsolatok, osztályok és megjelenítési színek.',
      'new_revision' => FALSE,
      'display_submitted' => FALSE,
    ]);
    $type->save();
  }

  $fields = [
    'field_muteti_registry_id' => ['integer', 'Alkalmazás-azonosító', []],
    'field_muteti_legacy_nid' => ['integer', 'Drupal 7 azonosító', []],
    'field_muteti_user' => ['entity_reference', 'Felhasználónév', ['target_type' => 'user']],
    'field_muteti_department' => ['string', 'Osztály', ['max_length' => 50]],
    'field_muteti_background' => ['string', 'Háttérszín', ['max_length' => 10]],
    'field_muteti_background_gif' => ['image', 'Háttér-GIF', ['uri_scheme' => 'public', 'default_image' => []]],
    'field_muteti_text_color' => ['string', 'Betűszín', ['max_length' => 10]],
    'field_muteti_active' => ['boolean', 'Aktív', []],
  ];
  foreach ($fields as $field_name => [$field_type, $label, $settings]) {
    $storage = \Drupal\field\Entity\FieldStorageConfig::loadByName('node', $field_name);
    if (!$storage) {
      $storage = \Drupal\field\Entity\FieldStorageConfig::create([
        'field_name' => $field_name,
        'entity_type' => 'node',
        'type' => $field_type,
        'cardinality' => 1,
        'settings' => $settings,
      ]);
      $storage->save();
    }
    $field = \Drupal\field\Entity\FieldConfig::loadByName('node', 'muteti_doctor', $field_name);
    if (!$field) {
      $field = \Drupal\field\Entity\FieldConfig::create([
        'field_storage' => $storage,
        'bundle' => 'muteti_doctor',
        'label' => $label,
        'required' => in_array($field_name, ['field_muteti_department', 'field_muteti_background', 'field_muteti_text_color'], TRUE),
      ]);
      if ($field_name === 'field_muteti_background_gif') {
        $field->setSettings([
          'file_directory' => 'muteti-orvos-hatterek',
          'file_extensions' => 'gif',
          'max_filesize' => '5 MB',
          'max_resolution' => '',
          'min_resolution' => '',
          'alt_field' => FALSE,
          'alt_field_required' => FALSE,
          'title_field' => FALSE,
          'title_field_required' => FALSE,
          'default_image' => [],
        ]);
      }
      $field->save();
    }
  }

  $title_override = \Drupal\Core\Field\Entity\BaseFieldOverride::loadByName('node', 'muteti_doctor', 'title');
  if (!$title_override) {
    $title_override = \Drupal\Core\Field\Entity\BaseFieldOverride::createFromBaseFieldDefinition(
      \Drupal::service('entity_field.manager')->getBaseFieldDefinitions('node')['title'],
      'muteti_doctor'
    );
  }
  $title_override->setLabel('Orvos neve')->save();

  $form_display = \Drupal::service('entity_display.repository')->getFormDisplay('node', 'muteti_doctor', 'default');
  $form_display
    ->setComponent('title', ['type' => 'string_textfield', 'weight' => 0])
    ->setComponent('field_muteti_user', ['type' => 'entity_reference_autocomplete', 'weight' => 10])
    ->setComponent('field_muteti_department', ['type' => 'string_textfield', 'weight' => 20])
    ->setComponent('field_muteti_background', ['type' => 'string_textfield', 'weight' => 30])
    ->setComponent('field_muteti_background_gif', ['type' => 'image_image', 'weight' => 35])
    ->setComponent('field_muteti_text_color', ['type' => 'string_textfield', 'weight' => 40])
    ->setComponent('field_muteti_active', ['type' => 'boolean_checkbox', 'weight' => 50])
    ->setComponent('field_muteti_registry_id', ['type' => 'number', 'weight' => 90])
    ->setComponent('field_muteti_legacy_nid', ['type' => 'number', 'weight' => 91])
    ->save();
}

/**
 * Adds optional animated GIF backgrounds to doctor content.
 */
function muteti_seb_update_11014(): void {
  $field_definitions = \Drupal::service('entity_field.manager')->getFieldStorageDefinitions('muteti_doctor');
  $schema = \Drupal::database()->schema();
  if (!$schema->fieldExists('muteti_doctor', 'background_gif')) {
    \Drupal::entityDefinitionUpdateManager()->installFieldStorageDefinition(
      'background_gif',
      'muteti_doctor',
      'muteti_seb',
      $field_definitions['background_gif']
    );
  }
  muteti_seb_ensure_doctor_content_type();
}

/**
 * Adds self-service doctor work/absence planning and monthly reports.
 */
function muteti_seb_update_11015(): void {
  $schema = \Drupal::database()->schema();
  if (!$schema->tableExists('muteti_doctor_availability')) {
    $schema->createTable('muteti_doctor_availability', muteti_seb_schema()['muteti_doctor_availability']);
  }
  foreach (['muteti_orvos1', 'muteti_orvos2', 'muteti_orvos3', 'muteti_boss'] as $role_id) {
    if ($role = Role::load($role_id)) {
      $role->grantPermission('manage own doctor availability');
      $role->grantPermission('view doctor availability');
      $role->save();
    }
  }
}

/**
 * Marks absences imported from the live Drupal 7 _szabi table.
 */
function muteti_seb_update_11016(): void {
  $schema = \Drupal::database()->schema();
  if (!$schema->fieldExists('muteti_doctor_availability', 'source')) {
    $schema->addField('muteti_doctor_availability', 'source', [
      'type' => 'varchar',
      'length' => 10,
      'not null' => TRUE,
      'default' => 'manual',
    ]);
  }
  if (!$schema->fieldExists('muteti_doctor_availability', 'legacy_id')) {
    $schema->addField('muteti_doctor_availability', 'legacy_id', [
      'type' => 'int',
      'unsigned' => TRUE,
      'not null' => FALSE,
    ]);
  }
}

/**
 * Adds department-level switches for absence and external-work features.
 */
function muteti_seb_update_11017(): void {
  $schema = \Drupal::database()->schema();
  foreach (['availability_enabled', 'away_enabled'] as $field) {
    if (!$schema->fieldExists('muteti_department_config', $field)) {
      $schema->addField('muteti_department_config', $field, [
        'type' => 'int',
        'size' => 'tiny',
        'not null' => TRUE,
        'default' => 1,
      ]);
    }
  }
}

/**
 * Moves temporarily stored oncology chart numbers into the TAJ column.
 */
function muteti_seb_update_11018(): void {
  $database = \Drupal::database();
  $departments = $database->select('muteti_department_config', 'd')
    ->fields('d', ['name'])
    ->condition('mode', 'onko')
    ->execute()
    ->fetchCol();
  foreach ($departments as $department) {
    $database->query(
      "UPDATE {muteti_appointment}
       SET taj = ward_room
       WHERE department = :department
         AND (taj IS NULL OR taj = '')
         AND ward_room IS NOT NULL
         AND ward_room <> ''",
      [':department' => $department]
    );
  }
}

