 * Adds the daily operating-room information panel storage.
 */
function muteti_seb_update_11019(): void {
  $schema = \Drupal::database()->schema();
  if (!$schema->tableExists('muteti_daily_info')) {
    $schema->createTable('muteti_daily_info', muteti_seb_schema()['muteti_daily_info']);
  }
}

