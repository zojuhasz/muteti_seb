      'mode' => ['type' => 'varchar', 'length' => 10, 'not null' => TRUE],
      'role_id' => ['type' => 'varchar', 'length' => 64, 'not null' => TRUE],
      'availability_enabled' => ['type' => 'int', 'size' => 'tiny', 'not null' => TRUE, 'default' => 1],
